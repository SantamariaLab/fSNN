#!/bin/bash -l
#SBATCH --job-name=SNN_cartpole
#SBATCH --output=out2.ext
#SBATCH --partition=compute1
#SBATCH --time=68:10:00
#SBATCH --ntasks=300
#SBATCH --cpus-per-task=1

module load anaconda3
conda activate cartpole
module load openmpi/5.0.3
#module load mpich

#srun run.py
mpirun -np 300 python run.py
