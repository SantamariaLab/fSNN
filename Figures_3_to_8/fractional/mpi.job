#!/bin/bash -l
#SBATCH --job-name=SNN_cartpole
#SBATCH --output=out.ext
#SBATCH --partition=compute1
#SBATCH --time=69:50:00
#SBATCH --ntasks=150
#SBATCH --cpus-per-task=1

module load anaconda3
conda activate cartpole
module load openmpi/5.0.3
